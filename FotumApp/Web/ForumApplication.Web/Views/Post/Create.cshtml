@model             ForumApplication.Web.ViewModels.Post.PostCreateInputViewModel
@{ 
    this.ViewData["Title"] = "New blog post";
    var categories = @Model.Categories.Select(x => new SelectListItem(x.Name, x.Id.ToString()));
}

<h1>@this.ViewData["Title"]</h1>

<script src="/lib/tinymce/tinymce.min.js" type="text/javascript"></script>
<script type="text/javascript">
    tinymce.init({
        selector: "textarea",
        plugins: [
            "image paste table link code media"
        ]
    });
</script>
<form method="post" asp-action="Create">
    <div class="form-group">

        <label asp-for="Title" class="form-group">Title</label>
        <input asp-for="Title" class="form-control" >
        <span asp-validation-for="Title"></span>
    </div>

    <div>
        <label asp-for="Content">Content</label>
        <textarea asp-for="Content" class="form-group"></textarea>
        <span asp-validation-for="Content"></span>
    </div>
    <div>
       <label asp-for="CategoryId">Category</label>        
      <select asp-for="CategoryId" asp-items="categories" class="form-group"></select>
        <span asp-for="CategoryId" class="text-danger"></span>
    </div>
    <hr />    
    <input type="submit" class="btn btn-primary" />
   
</form>